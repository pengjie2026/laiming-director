{
  "version": 2,
  "buildCommand": null,
  "functions": {
    "api/health.js": { "maxDuration": 10 },
    "api/script.js": { "maxDuration": 300 },
    "api/storyboard.js": { "maxDuration": 300 },
    "api/image.js": { "maxDuration": 300 },
    "api/tts.js": { "maxDuration": 300 },
    "api/review.js": { "maxDuration": 300 },
    "api/video.js": { "maxDuration": 300 },
    "api/prompt.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/script", "destination": "/api/script" },
    { "source": "/storyboard", "destination": "/api/storyboard" },
    { "source": "/image", "destination": "/api/image" },
    { "source": "/tts", "destination": "/api/tts" },
    { "source": "/review", "destination": "/api/review" },
    { "source": "/video", "destination": "/api/video" },
    { "source": "/prompt", "destination": "/api/prompt" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(script|storyboard|image|tts|review|video|health|prompt)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}

{
  "version": 2,
  "buildCommand": null,
  "functions": {
    "api/health.js": { "maxDuration": 10 },
    "api/script.js": { "maxDuration": 300 },
    "api/storyboard.js": { "maxDuration": 300 },
    "api/image.js": { "maxDuration": 300 },
    "api/tts.js": { "maxDuration": 300 },
    "api/review.js": { "maxDuration": 300 },
    "api/video.js": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
